// =========================================================================
// [구매] 테플론(PTFE) 와셔
// 구매: PTFE 와셔 OD36 × ID(SHAFT_D+0.5) × T1mm
// 하단 허브 보스 아래, 상판 단 바닥에 매립 (저마찰 베어링)
// 보스(9.3) + 와셔(1) = 10.3mm → 단(10mm)에 0.3mm 프리로드
// =========================================================================
include <_params.scad>

color([0.9, 0.9, 0.9]) difference() {
    cylinder(d=36, h=WASHER_T);
    translate([0, 0, -0.5]) cylinder(d=SHAFT_D + 0.5, h=WASHER_T + 1);
}
